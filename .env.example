DB_URL=r2dbc:postgresql://localhost:5432/pulsegate
DB_USERNAME=pulsegate_user
DB_PASSWORD=pulsegate_pass
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=10
POLL_INTERVAL_MS=500
MAX_RETRY_ATTEMPTS=3
DOCKERHUB_USERNAME=your_username
# Timezone the app + DB run in, so stored job timestamps match your wall clock.
# Use any IANA zone (e.g. Asia/Kolkata, America/New_York) or set to UTC for UTC storage.
TZ=Asia/Kolkata
